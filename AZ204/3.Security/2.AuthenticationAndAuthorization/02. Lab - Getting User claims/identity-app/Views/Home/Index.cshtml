@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-4">
    <h1 class="display-6">User Claims</h1>
    <p class="text-muted">Below are the claims received for the signed-in user.</p>
</div>

@if (User.Identity is not null && User.Identity.IsAuthenticated)
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Claim Type</th>
                <th>Claim Value</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var claim in User.Claims)
        {
            <tr>
                <td>@claim.Type</td>
                <td>@claim.Value</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning">
        No authenticated user found.
    </div>
}