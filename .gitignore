# .gitignore for workspace projects (PHP + .NET + common)

# OS
.DS_Store
Thumbs.db

# IDEs

.vs/
.idea/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs and temp
logs/
*.log
tmp/
temp/

# Visual Studio / Rider / Resharper
*.suo
*.user
*.userosscache
*.sln.docstates
_ReSharper*/
*.DotSettings.user

# .NET build folders and artifacts
bin/
obj/
**/bin/
**/obj/
publish/
Publish/
**/Publish/

# NuGet
*.nupkg
project.assets.json

# Build outputs
*.dll
*.exe
*.pdb
*.ilk
*.meta

# Runtime DB / local files
*.mdf
*.ldf
*.sqlite
*.db
*.db-shm
*.db-wal

# ASP.NET temporary files
ScaffoldingReadMe.txt

# PHP
vendor/
composer.phar
.env
.env.*

# PHP unit / test
coverage/
*.coverage
coverage.xml
.phpunit.result.cache

# Misc
*.zip
*.tar.gz
*.7z
