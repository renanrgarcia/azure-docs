# Repository-wide ignore rules for docs, .NET, Azure Functions, PHP, and common tooling.

# OS
.DS_Store
Thumbs.db

# Editors and IDEs
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.userprefs
*.sln.docstates
*.sln.iml
_ReSharper*/
*.DotSettings.user

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs and temp
logs/
*.log
tmp/
temp/

# .NET build folders and artifacts
bin/
obj/
**/bin/
**/obj/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
artifacts/
publish/
Publish/
**/Publish/
TestResults/
[Tt]est[Rr]esult*/
coverage/
*.coverage
*.coveragexml
*.trx

# NuGet
*.nupkg
project.assets.json
*.nuget.props
*.nuget.targets
**/packages/*
!**/packages/build/

# Publish and deployment outputs
*.[Pp]ublish.xml
*.azurePubxml
*.publishproj
*.publishsettings
PublishScripts/

# Azure Functions local secrets
local.settings.json

# Build outputs
*.dll
*.exe
*.pdb
*.ilk
*.meta

# Runtime DB / local files
*.mdf
*.ldf
*.sqlite
*.db
*.db-shm
*.db-wal

# ASP.NET temporary files
ScaffoldingReadMe.txt

# PHP
vendor/
composer.phar
.env
.env.*
.phpunit.result.cache

# Archives
*.zip
*.tar.gz
*.7z
